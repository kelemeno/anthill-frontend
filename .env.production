# Production build (Vercel) = the read-only showcase pointed at the Render backend.
# If your Render service URL differs from the default below, either edit these or
# override VITE_BACKEND_URL / VITE_WS_URL in the Vercel project's env settings
# (Vercel env vars take precedence over this file).
VITE_READ_ONLY=true
VITE_BACKEND_URL=https://anthill-backend.onrender.com/
VITE_WS_URL=wss://anthill-backend.onrender.com/
